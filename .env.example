# === DEPLOYMENT (Add these in Render Dashboard → Environment) ===
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://inferox-core-engine.onrender.com

# === RESEND (Get from https://resend.com/api-keys) ===
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Inferox <onboarding@resend.dev>

# === YOUR GMAIL (where contact form and notifications are sent) ===
OWNER_EMAIL=youremail@gmail.com

# === DATABASE (Render PostgreSQL or Neon) ===
DATABASE_URL=postgresql://user:pass@host:5432/inferox?sslmode=require

# === AUTH ===
JWT_SECRET=replace-with-64-char-random-string
OTP_TTL_SECONDS=600

# === SECURITY ===
ALLOWED_ORIGIN=https://inferox-core-engine.onrender.com